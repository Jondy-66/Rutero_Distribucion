
{
  "entities": {
    "ActiveLocation": {
      "title": "ActiveLocation",
      "type": "object",
      "description": "Ubicación en tiempo real del usuario.",
      "properties": {
        "userId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "heading": { "type": "number" },
        "accuracy": { "type": "number" },
        "address_text": { "type": "string" },
        "is_out_of_route": { "type": "boolean" }
      },
      "required": ["userId", "lat", "lng", "timestamp"]
    },
    "RouteHistory": {
      "title": "RouteHistory",
      "type": "object",
      "description": "Punto histórico en el rastro del usuario (breadcrumb).",
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Zone": {
      "title": "Zone",
      "type": "object",
      "description": "Geocerca o zona permitida para el usuario.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "geoJson": { "type": "object", "description": "Formato GeoJSON del polígono" }
      }
    },
    "Alert": {
      "title": "Alert",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["out_of_route"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "object" },
        "details": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "agent_id": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/active_locations/{userId}": { "schema": { "$ref": "#/entities/ActiveLocation" }, "description": "Posición en vivo" },
    "/route_history/{userId}/points/{pointId}": { "schema": { "$ref": "#/entities/RouteHistory" }, "description": "Historial de trayecto" },
    "/zones/{zoneId}": { "schema": { "$ref": "#/entities/Zone" }, "description": "Geocercas de supervisión" },
    "/alerts/{alertId}": { "schema": { "$ref": "#/entities/Alert" }, "description": "Alertas de seguridad" }
  }
}
